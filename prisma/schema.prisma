// Prisma 7 — l'URL de connexion est définie dans prisma.config.ts,
// mais le bloc datasource doit quand même être déclaré ici (provider only).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(AUTEUR)
  bio           String?
  institution   String?
  discipline    String?
  orcid         String?
  website       String?
  titreProfil   String?
  telephone     String?
  villeProfil   String?
  pays          String?
  linkedin      String?
  langues       String[]  @default([])
  expertises    String[]  @default([])
  suspended     Boolean   @default(false)
  permissions   String[]  @default([])
  deniedPermissions String[] @default([])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  articles          Article[]
  articlesRevue     ArticleRevue[]
  livres            Livre[]
  entretiens        Entretien[]
  expertProfile     ExpertProfile?
  coursCreated      Cours[]
  inscriptions      Inscription[]
  compteRendus      CompteRendu[]
  accounts          Account[]
  sessions          Session[]
  contactMessages   ContactMessage[]
  notifications     Notification[]
  editorialRequests EditorialRequest[]
  entretienComments EntretienComment[]
  entretienReactions EntretienReaction[]
  commandesPapier CommandePapier[]
}

enum Role {
  ADMIN
  AUTEUR
  LECTEUR
  EXPERT
  FORMATEUR
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SecurityEvent {
  id        String   @id @default(cuid())
  action    String
  keyHash   String
  createdAt DateTime @default(now())

  @@index([action, keyHash, createdAt])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  target    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model Opportunity {
  id          String   @id @default(cuid())
  slug        String   @unique
  titre       String
  organisation String
  type        String
  statut      String   @default("BROUILLON")
  payload     Json
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([statut, createdAt])
}

// ─── PILIER 1 : REVUE SCIENTIFIQUE ───────────────────────────────────────────

model ArticleRevue {
  id              String      @id @default(cuid())
  titre           String
  resume          String      @db.Text
  motsClés       String[]
  discipline      Discipline
  langue          Langue      @default(FR)
  doi             String?     @unique
  fichierUrl      String?
  statut          StatutRevue @default(EN_ATTENTE)
  accesLibre      Boolean     @default(false)
  vues            Int         @default(0)
  telechargements Int         @default(0)
  volume          Int?
  numero          Int?
  pages           String?
  auteurId        String
  auteur          User        @relation(fields: [auteurId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  submissionMeta  Json?
  coAuteurs       CoAuteur[]
}

enum StatutRevue {
  EN_ATTENTE
  EN_REVISION
  ACCEPTE
  PUBLIE
  REJETE
}

model CoAuteur {
  id             String       @id @default(cuid())
  nom            String
  email          String?
  institution    String?
  articleRevueId String
  articleRevue   ArticleRevue @relation(fields: [articleRevueId], references: [id], onDelete: Cascade)
}

// ─── PILIER 2 : CONSULTANCE ───────────────────────────────────────────────────

model ExpertProfile {
  id          String               @id @default(cuid())
  userId      String               @unique
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  titre       String
  specialites String[]
  cvUrl       String?
  tarifHeure  Float?
  disponible  Boolean              @default(true)
  ville       String?
  demandes    DemandeConsultance[]
  createdAt   DateTime             @default(now())
  submissionMeta Json?
}

model DemandeConsultance {
  id          String        @id @default(cuid())
  expertId    String
  expert      ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)
  nomClient   String
  emailClient String
  sujet       String
  description String        @db.Text
  budget      Float?
  delai       String?
  statut      StatutDemande @default(EN_ATTENTE)
  notes       String?       @db.Text
  updatedAt   DateTime      @updatedAt
  createdAt   DateTime      @default(now())
}

enum StatutDemande {
  EN_ATTENTE
  EN_COURS
  CLOTURE
}

// ─── PILIER 3 : MAGAZINE ─────────────────────────────────────────────────────

model Article {
  id          String        @id @default(cuid())
  titre       String
  slug        String        @unique
  chapeau     String
  contenu     String        @db.Text
  imageUrl    String?
  discipline  Discipline
  tags        String[]
  statut      StatutArticle @default(BROUILLON)
  vues        Int           @default(0)
  auteurId    String
  auteur      User          @relation(fields: [auteurId], references: [id])
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  submissionMeta Json?
}

enum StatutArticle {
  BROUILLON
  EN_ATTENTE
  PUBLIE
}

// ─── PILIER 4 : ENTRETIENS ────────────────────────────────────────────────────

model Entretien {
  id            String          @id @default(cuid())
  titre         String
  slug          String          @unique
  description   String
  format        FormatEntretien
  mediaUrl      String?
  transcription String?         @db.Text
  dureeMinutes  Int?
  imageUrl      String?
  discipline    Discipline
  statut        StatutArticle   @default(BROUILLON)
  vues          Int             @default(0)
  auteurId      String
  auteur        User            @relation(fields: [auteurId], references: [id])
  comments      EntretienComment[]
  reactions     EntretienReaction[]
  publishedAt   DateTime?
  createdAt     DateTime        @default(now())
  submissionMeta Json?
}

model EntretienComment {
  id          String    @id @default(cuid())
  entretienId String
  entretien   Entretien @relation(fields: [entretienId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contenu     String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([entretienId, createdAt])
  @@index([userId])
}

model EntretienReaction {
  id          String            @id @default(cuid())
  entretienId String
  entretien   Entretien         @relation(fields: [entretienId], references: [id], onDelete: Cascade)
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TypeReaction
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([entretienId, userId])
  @@index([entretienId, type])
}

enum TypeReaction {
  AIME
  COEUR
  INSPIRANT
  PERTINENT
}

enum FormatEntretien {
  PODCAST
  VIDEO
  TEXTE
}

// ─── PILIER 5 : ÉDITION ───────────────────────────────────────────────────────

model Livre {
  id            String      @id @default(cuid())
  titre         String
  slug          String      @unique
  description   String      @db.Text
  isbn          String?     @unique
  couvertureUrl String?
  extraitUrl    String?
  lienAchat     String?
  collection    String?
  discipline    Discipline
  annee         Int
  pages         Int?
  statut        StatutLivre @default(EN_ATTENTE)
  auteurId      String
  auteur        User        @relation(fields: [auteurId], references: [id])
  createdAt     DateTime    @default(now())
  submissionMeta Json?
}

enum StatutLivre {
  EN_ATTENTE
  PUBLIE
  REJETE
}

// ─── PILIER 6 : COLLOQUES ─────────────────────────────────────────────────────

model Colloque {
  id             String          @id @default(cuid())
  titre          String
  slug           String          @unique
  description    String          @db.Text
  lieu           String
  dateDebut      DateTime
  dateFin        DateTime
  dateLimit      DateTime?
  statut         StatutColloque  @default(A_VENIR)
  imageUrl       String?
  programmeUrl   String?
  actesUrl       String?
  discipline     Discipline[]
  sessions       Session_[]
  communications Communication[]
  createdAt      DateTime        @default(now())
}

enum StatutColloque {
  A_VENIR
  OUVERT
  CLOTURE
  ARCHIVE
}

model Session_ {
  id             String          @id @default(cuid())
  colloqueId     String
  colloque       Colloque        @relation(fields: [colloqueId], references: [id])
  titre          String
  horaire        DateTime
  lieu           String?
  animateur      String?
  communications Communication[]
}

model Communication {
  id         String      @id @default(cuid())
  colloqueId String
  colloque   Colloque    @relation(fields: [colloqueId], references: [id])
  sessionId  String?
  session    Session_?   @relation(fields: [sessionId], references: [id])
  titre      String
  auteurs    String
  resume     String      @db.Text
  discipline Discipline?
  fichierUrl String?
  statut     StatutRevue @default(EN_ATTENTE)
  createdAt  DateTime    @default(now())
  submissionMeta Json?
}

// ─── PILIER 7 : UNIVERSITÉ POPULAIRE ─────────────────────────────────────────

model Cours {
  id           String        @id @default(cuid())
  titre        String
  slug         String        @unique
  description  String        @db.Text
  imageUrl     String?
  niveau       Niveau        @default(DEBUTANT)
  discipline   Discipline
  dureeHeures  Int?
  gratuit      Boolean       @default(true)
  statut       StatutArticle @default(BROUILLON)
  formateurId  String
  formateur    User          @relation(fields: [formateurId], references: [id])
  chapitres    Chapitre[]
  inscriptions Inscription[]
  createdAt    DateTime      @default(now())
  submissionMeta Json?
}

model Chapitre {
  id            String        @id @default(cuid())
  coursId       String
  cours         Cours         @relation(fields: [coursId], references: [id])
  titre         String
  ordre         Int
  videoUrl      String?
  contenu       String?       @db.Text
  dureeMin      Int?
  quiz          Quiz[]
  comptesRendus CompteRendu[]
}

model Quiz {
  id         String   @id @default(cuid())
  chapitreId String
  chapitre   Chapitre @relation(fields: [chapitreId], references: [id])
  question   String
  options    String[]
  reponse    Int
}

model Inscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  coursId   String
  cours     Cours    @relation(fields: [coursId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, coursId])
}

model CompteRendu {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  chapitreId String
  chapitre   Chapitre @relation(fields: [chapitreId], references: [id], onDelete: Cascade)
  termine    Boolean  @default(false)

  @@unique([userId, chapitreId])
}

model CommandePapier {
  id             String                @id @default(cuid())
  typeProduit    TypeProduitPapier
  referenceId    String?
  titreProduit   String
  format         FormatPapier
  quantite       Int                   @default(1)
  nomClient      String
  emailClient    String
  telephone      String
  adresse        String                @db.Text
  ville          String
  pays           String
  notes          String?               @db.Text
  statut         StatutCommandePapier  @default(NOUVELLE)
  userId         String?
  user           User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([statut, createdAt])
  @@index([emailClient])
}

enum TypeProduitPapier {
  REVUE
  MAGAZINE
}

enum FormatPapier {
  LIVRE_RELIE
  DOS_CARRE
}

enum StatutCommandePapier {
  NOUVELLE
  CONFIRMEE
  EN_PREPARATION
  EXPEDIEE
  LIVREE
  ANNULEE
}

model ContactMessage {
  id        String    @id @default(cuid())
  nom       String
  email     String
  sujet     String
  message   String    @db.Text
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  statut    CrmStatut @default(NOUVEAU)
  notes     String?   @db.Text
  updatedAt DateTime  @updatedAt
  createdAt DateTime  @default(now())
}

model EditorialRequest {
  id           String                 @id @default(cuid())
  userId       String
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentType  String
  contentId    String
  contentTitle String
  kind         EditorialRequestKind
  message      String                 @db.Text
  response     String?                @db.Text
  statut       EditorialRequestStatus @default(EN_ATTENTE)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([contentType, contentId])
  @@index([userId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  titre     String
  message   String   @db.Text
  lien      String?
  lue       Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, lue, createdAt])
}

enum EditorialRequestKind {
  RETRAIT
  QUESTION
}

enum EditorialRequestStatus {
  EN_ATTENTE
  ACCEPTEE
  REFUSEE
  TRAITEE
}

enum CrmStatut {
  NOUVEAU
  EN_COURS
  EN_ATTENTE
  RESOLU
  ARCHIVE
}

// ─── ENUMS TRANSVERSAUX ───────────────────────────────────────────────────────

enum Discipline {
  SOCIOLOGIE
  ANTHROPOLOGIE
  HISTOIRE
  GEOGRAPHIE_HUMAINE
  ECONOMIE
  DROIT
  SCIENCE_POLITIQUE
  PHILOSOPHIE
  PSYCHOLOGIE_SOCIALE
  SCIENCES_EDUCATION
  LINGUISTIQUE
  COMMUNICATION
  DEMOGRAPHIE
  ETUDES_GENRE
  ETUDES_MALGACHES
  RELATIONS_INTERNATIONALES
}

enum Langue {
  FR
  MG
  EN
}

enum Niveau {
  DEBUTANT
  INTERMEDIAIRE
  AVANCE
}

// Note: Sur Vercel, prisma generate est exécuté automatiquement via le buildCommand
// Le client est généré dans node_modules/.prisma/client
