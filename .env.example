# ── Base de données : Vercel Postgres (Neon) ──────────────────────────────────
# Sur Vercel : Storage → Create Database → Postgres → connecte au projet
# Les variables ci-dessous sont injectées AUTOMATIQUEMENT par Vercel une fois
# la base connectée au projet (pas besoin de les copier-coller à la main).
#
# En LOCAL uniquement : récupère-les depuis Vercel Dashboard → ton projet →
# Storage → ta base → onglet ".env.local" → bouton "Copy Snippet"
DATABASE_URL="postgres://default:xxxxx@xxxxx-pooler.region.postgres.vercel-storage.com/verceldb?sslmode=require"
DIRECT_URL="postgres://default:xxxxx@xxxxx.region.postgres.vercel-storage.com/verceldb?sslmode=require"

# ── NextAuth ───────────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── Stockage fichiers ──────────────────────────────────────────────────────────
# Phase démo : fichiers stockés en local dans public/uploads/ — rien à configurer.
# Phase production (après achat domaine + hébergement) : on migrera vers Vercel Blob,
# une seule variable à ajouter alors : BLOB_READ_WRITE_TOKEN
